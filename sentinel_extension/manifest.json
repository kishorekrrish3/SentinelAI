{
  "manifest_version": 3,
  "name": "SentinelAI - Social Engineering Detector",
  "version": "1.0.0",
  "description": "AI-powered real-time detection and prevention of social engineering attacks",
  "permissions": [
    "activeTab",
    "storage",
    "alarms",
    "notifications",
    "scripting"
  ],
  "host_permissions": [
    "https://*.gmail.com/*",
    "https://*.outlook.com/*",
    "https://*.slack.com/*",
    "https://*.linkedin.com/*",
    "https://*.facebook.com/*",
    "https://*.twitter.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "lib/utils.js",
        "content/content.js"
      ],
      "css": [
        "styles/content.css"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/models/*",
        "lib/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  }
}